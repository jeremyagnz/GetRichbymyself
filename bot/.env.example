# ──────────────────────────────────────────────────────────────────────────────
# GetRichbymyself — Bot Webhook Server — Variables de Entorno
# Copia este archivo a .env y completa los valores.
# ¡NUNCA subas el archivo .env a Git!
# ──────────────────────────────────────────────────────────────────────────────

# Puerto en el que escucha el servidor (default: 3000)
PORT=3000

# Token secreto para validar que las alertas provienen de TradingView.
# Genera un string aleatorio largo, ej.: openssl rand -hex 32
# Luego añade este mismo token como query param en tu webhook URL:
#   https://tu-servidor.com/webhook?token=TU_TOKEN_SECRETO
WEBHOOK_SECRET=CAMBIA_ESTO_POR_UN_TOKEN_SEGURO

# ── Eightcap / MetaTrader 5 REST API ─────────────────────────────────────────
# Si usas un servidor MT5 REST (ej. EA de puente REST en MetaTrader):
MT5_API_URL=http://localhost:5000
MT5_API_KEY=TU_API_KEY_MT5

# ── Configuración de la cuenta ───────────────────────────────────────────────
# Número de cuenta de Eightcap (solo para logging/referencia)
ACCOUNT_ID=TU_NUMERO_DE_CUENTA

# ── Notificaciones opcionales (Telegram) ─────────────────────────────────────
# Si deseas recibir notificaciones por Telegram cuando se ejecute una orden:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
